generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cartao_ferramenta {
  id            Int        @id @default(autoincrement())
  codigo_uid    String     @db.VarChar(100)
  ativo         Boolean
  ferramenta_id Int
  ferramenta    ferramenta @relation(fields: [ferramenta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cartao_operador {
  id         Int     @id @default(autoincrement())
  codigo_uid String  @db.VarChar(100)
  ativo      Boolean
  user_cpf   String  @unique @db.VarChar(11)
  usuario    usuario @relation(fields: [user_cpf], references: [cpf], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model emprestimo {
  id              Int               @id @default(autoincrement())
  user_cpf        String            @db.VarChar(11)
  data_retirada   DateTime?         @default(now()) @db.Timestamp(6)
  status          String?           @db.VarChar(20)
  devolucao       devolucao?
  usuario         usuario           @relation(fields: [user_cpf], references: [cpf], onDelete: NoAction, onUpdate: NoAction)
  item_emprestimo item_emprestimo[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model estoque {
  id Int @id @default(autoincrement())
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ferramenta {
  id                 Int                  @id @default(autoincrement())
  tipo               String               @db.VarChar(50)
  cartao_ferramenta  cartao_ferramenta[]
  devolucao          devolucao[]
  ferramenta_estoque ferramenta_estoque[]
  item_emprestimo    item_emprestimo[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ferramenta_estoque {
  id            Int        @id @default(autoincrement())
  ferramenta_id Int
  quantidade    Int?       @default(0)
  status_saude  String     @db.VarChar(50)
  localizacao   String     @db.VarChar(50)
  ferramenta    ferramenta @relation(fields: [ferramenta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model leitura_nfc {
  id        Int       @id @default(autoincrement())
  data_hora DateTime? @default(now()) @db.Timestamp(6)
  uid_lido  String    @db.VarChar(100)
  sensor_id Int
  sensor    sensor    @relation(fields: [sensor_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sensor {
  id          Int           @id @default(autoincrement())
  tipo        String        @db.VarChar(50)
  medida      String        @db.VarChar(50)
  leitura_nfc leitura_nfc[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model usuario {
  cpf             String           @id @db.VarChar(11)
  nome            String           @db.VarChar(100)
  tipo            USERS_ROLE
  senha           String?
  setor           SETORES?
  cartao_operador cartao_operador?
  devolucao       devolucao[]
  emprestimo      emprestimo[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model devolucao {
  id             Int         @id @default(autoincrement())
  user_cpf       String      @db.VarChar(11)
  emprestimo_id  Int         @unique
  status         String?     @db.VarChar(20)
  data_devolucao DateTime?   @default(now()) @db.Timestamp(6)
  ferramenta_id  Int?
  emprestimo     emprestimo  @relation(fields: [emprestimo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ferramenta     ferramenta? @relation(fields: [ferramenta_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario        usuario     @relation(fields: [user_cpf], references: [cpf], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model item_emprestimo {
  id            BigInt      @id @default(autoincrement())
  emprestimo_id Int?
  ferramenta_id Int?
  quantidade    Int?        @db.SmallInt
  emprestimo    emprestimo? @relation(fields: [emprestimo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ferramenta    ferramenta? @relation(fields: [ferramenta_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum SETORES {
  SOLDA
  CORTE_LASER
  MONTAGEM
  PINTURA
  EL_TRICA      @map("ELÉTRICA")
  ALMOXARIFADO
  ADMINISTRACAO
}

enum USERS_ROLE {
  ALMOXARIFE
  OPERADOR
  ADMIN
}
